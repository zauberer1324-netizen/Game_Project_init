{
    "version":  1,
    "description":  "Project_game path policy. Workstreams propose in their own folders; the Orchestrator promotes accepted changes into central memory and game_project.",
    "protected_paths":  [
                            "CONTEXT.md",
                            "docs/contracts/",
                            "docs/orchestrator/ORCHESTRATOR_MEMORY.md",
                            "game_project/"
                        ],
    "workstream_required_outputs":  [
                                        "OUTPUT.md",
                                        "HANDOFF.md",
                                        "proposed_context_updates.md",
                                        "proposed_adr.md"
                                    ],
    "roles":  {
                  "workstream":  {
                                     "allowed_path_templates":  [
                                                                    "workstreams/{workstream}/"
                                                                ],
                                     "blocked_paths":  [
                                                           "CONTEXT.md",
                                                           "docs/contracts/",
                                                           "docs/orchestrator/ORCHESTRATOR_MEMORY.md",
                                                           "docs/prd/",
                                                           "docs/adr/",
                                                           "docs/issues/",
                                                           "docs/reports/",
                                                           "game_project/"
                                                       ]
                                 },
                  "orchestrator":  {
                                       "allowed_paths":  [
                                                             "*"
                                                         ],
                                       "central_update_requires_any":  [
                                                                           "docs/orchestrator/ORCHESTRATOR_MEMORY.md",
                                                                           "docs/reports/",
                                                                           "docs/adr/",
                                                                           "docs/prd/",
                                                                           "docs/issues/",
                                                                           "runs/"
                                                                       ]
                                   },
                  "precommit":  {
                                    "central_update_requires_any":  [
                                                                        "docs/orchestrator/ORCHESTRATOR_MEMORY.md",
                                                                        "docs/reports/",
                                                                        "docs/adr/",
                                                                        "docs/prd/",
                                                                        "docs/issues/",
                                                                        "runs/"
                                                                    ],
                                    "allow_infrastructure_changes":  true
                                }
              },
    "infrastructure_paths":  [
                                 ".gitignore",
                                 ".githooks/",
                                 "orchestrator.config.json",
                                 "workspace_policy.json",
                                 "scripts/",
                                 "orchestrator_project/scripts/",
                                 "orchestrator_project/context_manager/",
                                 "orchestrator_project/examples/",
                                 "docs/maps/",
                                 "docs/orchestrator/MEMORY_PROTOCOL.md",
                                 "template.config.json",
                                 "engine_profiles/",
                                 "docs/startup/",
                                 "docs/rubrics/",
                                 "docs/git/"
                             ]
}